pipeline{
    agent any

    parameters{
        booleanParam(name: 'SKIP_TERRAFORM', defaultValue: false, description: 'Provide IP to run Ansible only')

        booleanParam(
            name: 'SKIP_ANSIBLE', 
            defaultValue: false, 
            description: 'Skip Ansible and run Terraform only'
        )
    }

    

    environment{
        ARM_secret_key       = credentials('secret_key')
        ARM_access_key      = credentials('access_key')
        
        TF_VAR_secret_key       = credentials('secret_key')
        TF_VAR_access_key      = credentials('access_key')
        TF_BIN               = ''

    }
    stages{
        stage('Setup Terraform') {
            steps {
                script {
                    // Check if terraform exists, if not download and extract
                    def tfFound = sh(script: 'which terraform', returnStatus: true)
                    if (tfFound != 0) {
                        echo "Terraform not found in PATH, downloading version 1.9.8..."
                        sh '''
                            mkdir -p ${WORKSPACE}/.terraform-bin
                            cd ${WORKSPACE}/.terraform-bin
                            curl -fsSL https://releases.hashicorp.com/terraform/1.9.8/terraform_1.9.8_linux_amd64.zip -o terraform.zip
                            
                            if command -v jar >/dev/null 2>&1; then
                                jar xf terraform.zip
                            elif command -v unzip >/dev/null 2>&1; then
                                unzip -o terraform.zip
                            else
                                apt-get update -qq && apt-get install -y unzip >/dev/null 2>&1 || yum install -y unzip >/dev/null 2>&1
                                unzip -o terraform.zip
                            fi
                            
                            chmod +x terraform
                            ./terraform version
                        '''
                        env.TF_BIN = '${WORKSPACE}/.terraform-bin/terraform'
                    } else {
                        sh 'which terraform'
                        env.TF_BIN = 'terraform'
                    }
                }
            }
        }

        stage('Terraform init') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terrafrom') {
                    sh 'rm -rf .terraform .terraform.lock.hcl'
                    sh "${TF_BIN} init -reconfigure"
                }
                  
                
            }
        }

        stage('Terraform plan') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terrafrom') {
                    sh "${TF_BIN} plan -out=tfplan"
                }
            }
        }

        stage('Terraform apply') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terrafrom') {
                    sh "${TF_BIN} apply -auto-approve tfplan"
                }
            }
        }

        stage('Terraform output') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terrafrom') {
                    script {
                        env.PUBLIC_IP = sh(script: "${TF_BIN} output -raw public_ip", returnStdout: true).trim()
                        echo "Public IP: ${env.PUBLIC_IP}"

                        env.SERVER_NAME = sh(script: "${TF_BIN} output -raw vm_admin_username", returnStdout: true).trim()
                        echo "Server Name: ${env.SERVER_NAME}"

                        writeFile file: 'output/ServerName', text: "${env.SERVER_NAME}"
                        writeFile file: 'output/PublicIP', text: "${env.PUBLIC_IP}"
                       
                    }
                }
            }
        }

        stage('Archive artifacts') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                archiveArtifacts artifacts: 'DevOps/terrafrom/output/*', fingerprint: true
            }
        }


       // #---------------------------------------------------------------#
          // # Ansible stage 

        stage('ssh-keyscan') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    withCredentials([sshUserPrivateKey(credentialsId: 'SSH_USER', keyFileVariable: 'SSH_KEY' , usernameVariable: 'SSH_USER')]) {
                        sh '''
                            mkdir -p ~/.ssh
                            cp ${SSH_KEY} ~/.ssh/id_rsa
                            chmod 600 ~/.ssh/id_rsa
                            ssh-keyscan -H ${PUBLIC_IP} >> ~/.ssh/known_hosts
                        '''
                    }
                }
            }
        }

        stage('ssh connection') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                
                withCredentials([sshUserPrivateKey(credentialsId: 'SSH_USER', keyFileVariable: 'SSH_KEY' , usernameVariable: 'SSH_USER')]) {
                    sh '''
                        ssh -o StrictHostKeyChecking=no -i ${SSH_KEY} ${SSH_USER}@${PUBLIC_IP} "echo 'SSH connection successful!'"
                        
                    '''
                }
                
            }
        }

        stage('Generate inventory') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    script {
                        writeFile file: 'ansible_inventory.ini', text: """[webservers]
server ansible_host=${env.PUBLIC_IP} ansible_user=${env.SERVER_NAME} ansible_ssh_private_key_file=/var/lib/jenkins/.ssh/id_rsa
"""
                        sh 'cat ansible_inventory.ini'
                    }
                }
            }
        }

        stage('Run Ansible Playbook') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    sh 'ansible-playbook -i ansible_inventory.ini playbook.yml'
                }
            }
        }

        stage("Test Connection") {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    sh 'ansible -i ansible_inventory.ini webservers -m ping'
                }
            }

        }
        

            
    }
}