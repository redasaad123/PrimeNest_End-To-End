pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-sa
  containers:
  - name: tools
    image: alpine/kubectl:latest
    command: ["cat"]
    tty: true
  - name: helm
    image: alpine/helm:latest
    command: ["cat"]
    tty: true
'''
        }
    }

    environment {
        jwtKey = credentials('jwtKey')
        connectionString = credentials('connectionString')
    }

    stages {

        stage('Checkout') {
            steps {
                container('tools') {
                    git branch: 'main', url: 'https://github.com/redasaad123/PrimeNest_End-To-End.git'
                }
            }
        }

        stage('Create Secret') {
            steps {
                container('tools') {
                    sh '''
cat <<EOF > secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: primenest-secret
type: Opaque
stringData:
  jwt-Key: "${jwtKey}"
  connectionString: "${connectionString}"
EOF

kubectl apply -f secret.yaml
'''
                }
            }
        }

        stage('Deploy the Application') {
            steps {
                container('helm') {
                    dir('DevOps/Helm') {
//                         sh '''
// // kubectl apply -f ConfigMap.yml
// //         kubectl apply -f StorageClass.yml
// //         kubectl apply -f PVC.yml
// //         kubectl apply -f Deployment.yml
// //         kubectl apply -f Services.yml
// // kubectl apply -f ClusterIssuer.yml
// //         kubectl apply -f Ingress.yml

// // kubectl rollout status deployment/primenest
// '''

                        sh '''
                        helm upgrade --install primenest . 
                        '''
                    }
                }
            }
        }
    }
}