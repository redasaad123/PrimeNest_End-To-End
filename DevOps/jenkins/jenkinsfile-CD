pipeline{
    agent none

    environment {
        jwtKey = credentials('jwtKey')
        connectionString = credentials('connectionString')
    }
    stages{
        stage('Checkout') {
            agent {
                kubernetes {
                    yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: dotnet
    image: mcr.microsoft.com/dotnet/sdk:8.0
    command: ["cat"]
    tty: true
'''
                }
            }

            steps {
                container('dotnet') {
                    git branch: 'main', url: 'https://github.com/redasaad123/PrimeNest_End-To-End.git'
                }
            }
        }

        stage('Create Secret') {
            agent {
                kubernetes {
                    yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ["cat"]
    tty: true
'''
                }
            }
            steps {
                container('kubectl') {
                    sh'''
                cat <<EOF > secret.yaml
apiVersion: v1
kind: Secret
metadata:
    name: primenest-secret
type: Opaque

stringData:
    jwt-Key: "${jwtKey}" 
    connectionString: "${connectionString}"
EOF

kubectl apply -f secret.yaml

                    '''
                }
            }
        }

        stage('Deploy to Kubernetes') {
            agent {
                kubernetes {
                    yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kubectl
    image: bitnami/kubectl:latest
    command: ["cat"]
    tty: true
'''
                }
            }
            steps {
                container('kubectl') {
                    dir('DevOps/K8s') {
                        sh'''
kubectl apply -f ConfigMap.yml
kubectl apply -f StorageClass.yaml
kubectl apply -f pvc.yaml
kubectl apply -f Deployment.yaml
kubectl apply -f Services.yaml
kubectl apply -f ClusterIssuer.yml
kubectl apply -f Ingress.yaml

                    '''
                    }
                }
            }
        }
                
                
                





        
        
    }
}