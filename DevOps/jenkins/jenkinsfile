pipeline{
    agent any

    parameters{
        booleanParam(name: 'SKIP_TERRAFORM', defaultValue: false, description: 'Provide IP to run Ansible only')

        booleanParam(
            name: 'SKIP_ANSIBLE', 
            defaultValue: false, 
            description: 'Skip Ansible and run Terraform only'
        )
    }

    

    environment{
        AWS_ACCESS_KEY_ID     = credentials('access_key')
        AWS_SECRET_ACCESS_KEY = credentials('secret_key')
        AWS_REGION            = 'eu-central-1'
        AWS_DEFAULT_REGION    = 'eu-central-1'

        TF_VAR_secret_key       = credentials('secret_key')
        TF_VAR_access_key      = credentials('access_key')
        TF_BIN               = ''
        ANSIBLE_PLAYBOOK_BIN = 'ansible-playbook'
        ANSIBLE_BIN          = 'ansible'

    }
    stages{
        stage('Setup Terraform') {
            steps {
                script {
                    // Check if terraform exists, if not download and extract
                    def tfFound = sh(script: 'which terraform', returnStatus: true)
                    if (tfFound != 0) {
                        echo "Terraform not found in PATH, downloading version 1.9.8..."
                        sh '''
                            mkdir -p ${WORKSPACE}/.terraform-bin
                            cd ${WORKSPACE}/.terraform-bin
                            curl -fsSL https://releases.hashicorp.com/terraform/1.9.8/terraform_1.9.8_linux_amd64.zip -o terraform.zip
                            
                            if command -v jar >/dev/null 2>&1; then
                                jar xf terraform.zip
                            elif command -v unzip >/dev/null 2>&1; then
                                unzip -o terraform.zip
                            else
                                apt-get update -qq && apt-get install -y unzip >/dev/null 2>&1 || yum install -y unzip >/dev/null 2>&1
                                unzip -o terraform.zip
                            fi
                            
                            chmod +x terraform
                            ./terraform version
                        '''
                        // Prepend terraform binary directory to PATH
                        env.PATH = "${WORKSPACE}/.terraform-bin:${env.PATH}"
                    } else {
                        sh 'terraform version'
                    }
                    
                    // Ensure ansible is available
                    if (!sh(script: 'command -v ansible-playbook', returnStatus: true).toInteger().equals(0)) {
                        echo "Ansible not found, installing..."
                        if (sh(script: 'command -v pip3 >/dev/null 2>&1', returnStatus: true) == 0) {
                            sh 'pip3 install --user ansible-core'
                            env.PATH = "${env.HOME}/.local/bin:${env.PATH}"
                        } else if (sh(script: 'command -v apt-get >/dev/null 2>&1', returnStatus: true) == 0) {
                            sh 'apt-get update -qq && apt-get install -y ansible'
                        } else if (sh(script: 'command -v yum >/dev/null 2>&1', returnStatus: true) == 0) {
                            sh 'yum install -y ansible'
                        } else {
                            error('No supported package manager found to install Ansible (pip3/apt-get/yum)')
                        }
                        env.ANSIBLE_PLAYBOOK_BIN = sh(script: 'command -v ansible-playbook || echo ${HOME}/.local/bin/ansible-playbook', returnStdout: true).trim()
                        env.ANSIBLE_BIN = sh(script: 'command -v ansible || echo ${HOME}/.local/bin/ansible', returnStdout: true).trim()
                        sh "${env.ANSIBLE_PLAYBOOK_BIN} --version"
                    } else {
                        env.ANSIBLE_PLAYBOOK_BIN = sh(script: 'command -v ansible-playbook', returnStdout: true).trim()
                        env.ANSIBLE_BIN = sh(script: 'command -v ansible', returnStdout: true).trim()
                        sh "${env.ANSIBLE_PLAYBOOK_BIN} --version"
                    }
                }
            }
        }

        stage('Terraform init') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terraform') {
                    sh 'rm -rf .terraform .terraform.lock.hcl'
                    sh 'terraform init -reconfigure'
                }
                  
                
            }
        }

        stage('Terraform plan') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terraform') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Terraform apply') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terraform') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Terraform output') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                dir('DevOps/terraform') {
                    script {
                        env.PUBLIC_IP = sh(script: 'terraform output -raw public_ip', returnStdout: true).trim()
                        echo "Public IP: ${env.PUBLIC_IP}"

                        env.SERVER_NAME = sh(script: 'terraform output -raw vm_admin_username', returnStdout: true).trim()
                        echo "Server Name: ${env.SERVER_NAME}"

                        writeFile file: 'output/ServerName', text: "${env.SERVER_NAME}"
                        writeFile file: 'output/PublicIP', text: "${env.PUBLIC_IP}"
                       
                    }
                }
            }
        }

        stage('Archive artifacts') {
            when { expression { return !params.SKIP_TERRAFORM }} 
            steps {
                archiveArtifacts artifacts: 'DevOps/terraform/output/*', fingerprint: true
            }
        }


       // #---------------------------------------------------------------#
          // # Ansible stage 

        stage('ssh-keyscan') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    withCredentials([sshUserPrivateKey(credentialsId: 'SSH_USER', keyFileVariable: 'SSH_KEY' , usernameVariable: 'SSH_USER')]) {
                        sh '''
                            mkdir -p ~/.ssh
                            cp ${SSH_KEY} ~/.ssh/id_rsa
                            chmod 600 ~/.ssh/id_rsa
                            ssh-keyscan -H ${PUBLIC_IP} >> ~/.ssh/known_hosts
                        '''
                    }
                }
            }
        }

        stage('ssh connection') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                
                withCredentials([sshUserPrivateKey(credentialsId: 'SSH_USER', keyFileVariable: 'SSH_KEY' , usernameVariable: 'SSH_USER')]) {
                    sh '''
                        mkdir -p ~/.ssh
                        cp ${SSH_KEY} ~/.ssh/id_rsa
                        chmod 600 ~/.ssh/id_rsa
                        ssh -o IdentitiesOnly=yes -o StrictHostKeyChecking=no -i ~/.ssh/id_rsa ${SSH_USER}@${PUBLIC_IP} "echo 'SSH connection successful!'"
                        
                    '''
                }
                
            }
        }

        stage('Generate inventory') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    script {
                        writeFile file: 'ansible_inventory.ini', text: """[webservers]
server ansible_host=${env.PUBLIC_IP} ansible_user=${env.SERVER_NAME} ansible_ssh_private_key_file=/home/jenkins/.ssh/id_rsa
"""
                        sh 'cat ansible_inventory.ini'
                    }
                }
            }
        }

        stage('Run Ansible Playbook') {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    sh "${env.ANSIBLE_PLAYBOOK_BIN} -i ansible_inventory.ini playbook.yml"
                }
            }
        }

        stage("Test Connection") {
            when { expression { return !params.SKIP_ANSIBLE }} 
            steps {
                dir('DevOps/ansible') {
                    sh "${env.ANSIBLE_BIN} -i ansible_inventory.ini webservers -m ping"
                }
            }

        }
        

            
    }
}